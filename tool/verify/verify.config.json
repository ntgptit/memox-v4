{
  "$schema": "see tool/verify/run.mjs",
  "stack": "flutter",
  "src": "lib",
  "steps": {
    "analyze": {
      "cmd": "flutter analyze"
    },
    "format": {
      "cmd": "dart format --output=none --set-exit-if-changed ."
    },
    "gen_l10n": {
      "cmd": "flutter gen-l10n"
    },
    "test": {
      "cmd": "flutter test"
    },
    "parity_contract": {
      "cmd": "node tool/parity/gen_parity_contract.mjs --check"
    },
    "parity_fe_keys": {
      "cmd": "node tool/parity/fe_node_usage.mjs --check --screen dashboard"
    }
  },
  "chains": {
    "quick": [
      "analyze"
    ],
    "code": [
      "doc_guard",
      "gen_l10n",
      "analyze",
      "format",
      "parity_contract",
      "parity_fe_keys"
    ],
    "full": [
      "doc_guard",
      "gen_l10n",
      "analyze",
      "format",
      "parity_contract",
      "parity_fe_keys",
      "test"
    ],
    "docs": [
      "doc_guard",
      "parity_contract"
    ]
  },
  "docGuard": "node tool/doc_guard/run.mjs check"
}
