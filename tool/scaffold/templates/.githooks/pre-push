#!/bin/sh
# pre-push — last gate before code leaves the machine.
#
# Re-runs doc_guard so a push can never carry doc-code drift (a doc referencing a
# path/symbol that no longer exists). Cheap and deterministic; no network.
#
# Extend this with project-specific push-time checks (design sync, full test run,
# etc.) as the project grows.
set -e

if ! command -v node >/dev/null 2>&1; then
  echo "pre-push: node not found; skipping doc_guard." >&2
  exit 0
fi

node tool/doc_guard/run.mjs check
