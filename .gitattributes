# Normalize line endings. Text files are stored LF in the repo; Git may still
# check them out per core.autocrlf. The paths below are pinned to LF in the
# WORKING TREE too, so tools that compare bytes (e.g. the Tier-0 token
# generator's --check gate) don't false-positive on CRLF conversion on Windows.

* text=auto

# Generated Dart token mirrors + the generators — LF everywhere.
lib/core/theme/mx_*.dart text eol=lf
tool/design/*.mjs        text eol=lf
tool/verify/*.mjs        text eol=lf
# Generated loop prompts + queue — LF (stops CRLF churn on every regeneration).
docs/agent/build/**      text eol=lf
# Font/binary assets — never normalize line endings.
*.ttf                    binary
*.otf                    binary
# Git hooks + CI workflows — LF everywhere (a CRLF shebang breaks `/bin/sh` hooks).
.githooks/*              text eol=lf
.github/workflows/*      text eol=lf
# Flutter-generated platform plugin registrants — LF (stop recurring churn).
linux/flutter/generated_*        text eol=lf
macos/Flutter/GeneratedPluginRegistrant.swift text eol=lf
windows/flutter/generated_*      text eol=lf
