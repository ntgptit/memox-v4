# verify pass-marker is local state, never commit it
tool/verify/.last-pass.json

# dependencies / build output (prune for your stack)
node_modules/
dist/
build/
.dart_tool/
target/
__pycache__/
*.pyc
.venv/

# Flutter tool state — machine-specific, regenerated by `flutter pub get`
.flutter-plugins-dependencies

# nested independent repo — has its own git/remote (code-verification-guard-v2),
# committed separately; memox-v4 must not track it.
code-verification-guard/

# editor / OS
.idea/
.DS_Store
*.zip
.claude/scheduled_tasks.lock

# Drift web worker build artifacts (the .js is committed; these regenerate)
web/drift_worker.dart.js.deps
web/drift_worker.dart.js.map

# Generated FE style specs (regenerated by test/parity/fe_spec_export_test.dart)
tool/parity/fe-specs/

# Generated app screenshots (regenerate: MEMOX_SHOT=1 flutter test ... --update-goldens)
test/parity/shots/
