# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Codegen outputs (build_runner) — regenerated locally, never committed.
# Agents: do NOT read these; regenerate with `dart run build_runner build`.
*.g.dart
*.drift.dart
*.freezed.dart
*.mocks.dart

# Generated localizations (flutter gen-l10n) — regenerated from lib/l10n/*.arb.
# Agents: do NOT read these; regenerate with `flutter gen-l10n`.
lib/l10n/app_localizations*.dart

# Kit-first guard markers (tool/hooks/kit-first-guard.mjs) — per-session, local.
tool/hooks/.kit-acks/

# code-verification-guard-v2 — a separate nested git repo (its own tooling),
# not part of this project. Ignore so it is never embedded/tracked here.
/code-verification-guard-v2/

# Screen goldens are regenerated in CI (ubuntu) and diffed against the kit
# shots (tool/visual-diff) — never committed. The token_swatch baselines beside
# them ARE committed.
/test/golden/goldens/screens/
