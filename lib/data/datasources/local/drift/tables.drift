-- MemoX V4 — local schema (schema_version = 1).
-- SQL is the source of the table shape; embedded into AppDatabase via
-- `@DriftDatabase(include: {'tables.drift'})` and compiled by drift_dev.
-- Mirrors docs/database/schema-contract.md exactly (table/column names, FKs,
-- cascade, indexes). A change here is a schema change → update the schema +
-- migration contracts + a migration test in the same commit (CLAUDE.md).

-- The language pair content belongs to.
CREATE TABLE language_pair (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  source_lang TEXT NOT NULL,
  target_lang TEXT NOT NULL,
  order_index INTEGER NOT NULL DEFAULT 0
);

-- Self-nesting deck tree via parent_deck_id (no separate folder table).
CREATE TABLE deck (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  pair_id INTEGER NOT NULL REFERENCES language_pair(id) ON DELETE CASCADE,
  parent_deck_id INTEGER REFERENCES deck(id) ON DELETE CASCADE,
  name TEXT NOT NULL,
  order_index INTEGER NOT NULL DEFAULT 0
);

CREATE INDEX idx_deck_tree ON deck (pair_id, parent_deck_id, order_index);

-- A flashcard; hidden removes it from the queue and due counts.
CREATE TABLE card (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  deck_id INTEGER NOT NULL REFERENCES deck(id) ON DELETE CASCADE,
  term TEXT NOT NULL,
  gender TEXT,
  audio_ref TEXT,
  hidden BOOLEAN NOT NULL DEFAULT FALSE,
  order_index INTEGER NOT NULL DEFAULT 0,
  created_at INTEGER NOT NULL,      -- epoch ms
  last_studied_at INTEGER           -- epoch ms
);

CREATE INDEX idx_card_deck_order ON card (deck_id, order_index);

-- One free-text meaning per language.
CREATE TABLE card_meaning (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  card_id INTEGER NOT NULL REFERENCES card(id) ON DELETE CASCADE,
  lang TEXT NOT NULL,
  content TEXT NOT NULL   -- free-text meaning; named `content` (not `text`,
                          -- which collides with Drift's text() column builder)
);

CREATE INDEX idx_meaning_card ON card_meaning (card_id);

-- One row per card (single-direction Leitner schedule).
CREATE TABLE srs_state (
  card_id INTEGER NOT NULL PRIMARY KEY REFERENCES card(id) ON DELETE CASCADE,
  box INTEGER NOT NULL DEFAULT 0,
  due_at INTEGER,                   -- epoch ms; null = new, unscheduled
  last_result TEXT,                 -- 'correct' / 'wrong'
  reviewed_at INTEGER               -- epoch ms
);

CREATE INDEX idx_srs_due ON srs_state (due_at);

-- Per-day study totals (only DueReview / NewLearn add to it).
CREATE TABLE daily_activity (
  day TEXT NOT NULL,                -- YYYY-MM-DD (machine clock)
  pair_id INTEGER NOT NULL REFERENCES language_pair(id) ON DELETE CASCADE,
  seconds INTEGER NOT NULL DEFAULT 0,
  words INTEGER NOT NULL DEFAULT 0,
  PRIMARY KEY (day, pair_id)
);

-- Flat key-value store (theme, SRS, game, reminders, goals).
CREATE TABLE settings (
  "key" TEXT NOT NULL PRIMARY KEY,   -- quoted: KEY is a SQL keyword
  value TEXT
);

-- Per-grade review outcomes for accuracy stats (W9). Append-only; added in
-- schema v2 (see migration-contract 1→2).
CREATE TABLE review_outcome (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  card_id INTEGER NOT NULL REFERENCES card(id) ON DELETE CASCADE,
  pair_id INTEGER NOT NULL REFERENCES language_pair(id) ON DELETE CASCADE,
  ts INTEGER NOT NULL,               -- epoch ms (machine clock)
  correct INTEGER NOT NULL,          -- 0 / 1
  mode TEXT NOT NULL                 -- 'dueReview' / 'newLearn'
);

CREATE INDEX idx_review_outcome_pair_ts ON review_outcome (pair_id, ts);
